# Copy this file to .env, then replace every placeholder before deployment.

# ===== DJANGO CORE SETTINGS =====
DEBUG=True
SECRET_KEY=replace-with-a-generated-django-secret-key
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1

# ===== EMAIL CONFIGURATION =====
# Available providers: console, smtp, brevo, dummy, filebased, locmem
EMAIL_BACKEND=console
EMAIL_MAX_RETRIES=2
EMAIL_HTTP_TIMEOUT=20

# Required when EMAIL_BACKEND=brevo
BREVO_API_KEY=

# Required when EMAIL_BACKEND=smtp
EMAIL_HOST=smtp-relay.brevo.com
EMAIL_PORT=587
EMAIL_USE_TLS=True
EMAIL_HOST_USER=
EMAIL_HOST_PASSWORD=

DEFAULT_FROM_EMAIL=noreply@example.com
SERVER_EMAIL=noreply@example.com

# ===== SITE / CHECKOUT =====
SITE_URL=http://localhost:8000
TAX_RATE_PERCENT=0
USD_TO_GNF=9100
SHIP_CONAKRY_GNF=15000
SHIP_GUINEA_GNF=20000
SHIP_INTL_USD=10
PRODUCT_NOTIFICATIONS_ENABLED=True

# ===== SECURITY SETTINGS =====
# Keep these disabled for local HTTP development.
SECURE_SSL_REDIRECT=False
SECURE_HSTS_SECONDS=0
SECURE_HSTS_INCLUDE_SUBDOMAINS=False
SECURE_HSTS_PRELOAD=False

# Enable only behind a trusted HTTPS reverse proxy.
USE_PROXY_SSL_HEADER=False
CSRF_TRUSTED_ORIGINS=

# ===== RATE LIMITING =====
RATELIMIT_ENABLE=True
MAX_LOGIN_ATTEMPTS=5
LOCKOUT_DURATION=900
REQUIRE_EMAIL_VERIFICATION_ATTEMPTS=10

# ===== OTP SETTINGS =====
OTP_EXPIRATION_MINUTES=10
OTP_RESEND_LIMIT=5
OTP_RESEND_COOLDOWN_MINUTES=2

# ===== SMS CONFIGURATION (TWILIO) =====
SMS_ENABLED=False
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_PHONE_NUMBER=

# ===== BUSINESS INFORMATION =====
BUSINESS_NAME=TEEBUSINESS
BUSINESS_PHONE=+224 623 70 78 33
BUSINESS_EMAIL=support@example.com

# ===== SOCIAL MEDIA / WHATSAPP =====
SOCIAL_TIKTOK=
SOCIAL_FACEBOOK=
WHATSAPP_NUMBER=224623707833
WHATSAPP_MESSAGE=Hello, I would like information about your products.
