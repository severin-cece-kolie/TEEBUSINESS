# ===== DJANGO CORE SETTINGS =====
# Set to True for local development, False for production
DEBUG=True
# CHANGE THIS BEFORE PRODUCTION! Generate with: python manage.py shell -c "from django.core.management.utils import get_random_secret_key; print(get_random_secret_key())"
SECRET_KEY=2ym3b)t5d^1xl3h*v$1ob0%t0obl&j+^nl&j=spdur$0&lk7x2
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1

# ===== EMAIL CONFIGURATION =====
# Use 'console' backend for local testing (prints emails to console)
# Use 'smtp' or other backends only with proper credentials for testing
EMAIL_BACKEND=console
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USE_TLS=True
# Replace with your actual email credentials ONLY when testing real emails
EMAIL_HOST_USER=your-email@gmail.com
EMAIL_HOST_PASSWORD=your-app-password
DEFAULT_FROM_EMAIL=your-email@gmail.com
SERVER_EMAIL=your-email@gmail.com

# ===== Brevo (formerly Sendinblue) =====
BREVO_API_KEY=your-brevo-api-key

# ===== Mailgun =====
MAILGUN_API_KEY=your-mailgun-api-key
MAILGUN_DOMAIN=your-domain.mailgun.org

# ===== Amazon SES =====
AWS_ACCESS_KEY_ID=your-aws-access-key
AWS_SECRET_ACCESS_KEY=your-aws-secret-key
AWS_SES_REGION=us-east-1

# ===== SendGrid =====
SENDGRID_API_KEY=your-sendgrid-api-key

# ===== SMS CONFIGURATION (Twilio) =====
SMS_ENABLED=False
TWILIO_ACCOUNT_SID=your-twilio-account-sid
TWILIO_AUTH_TOKEN=your-twilio-auth-token
TWILIO_PHONE_NUMBER=+1234567890

# ===== SECURITY SETTINGS =====
# For local development: set all to False
# For production behind Cloudflare/HTTPS: set these to True
SECURE_SSL_REDIRECT=False
SECURE_HSTS_SECONDS=0
SECURE_HSTS_INCLUDE_SUBDOMAINS=False
SECURE_HSTS_PRELOAD=False
SESSION_COOKIE_SECURE=False
CSRF_COOKIE_SECURE=False

# ===== PROXY / CLOUDFLARE (production) =====
# Site URL used to build absolute links in emails.
SITE_URL=http://localhost:8000
# Set True only when the app always runs behind Cloudflare or a trusted proxy
# that terminates TLS and sets X-Forwarded-Proto. Lets request.is_secure() work.
USE_PROXY_SSL_HEADER=False
# Comma-separated production origins allowed for CSRF (scheme required).
# e.g. https://teebusiness.com,https://www.teebusiness.com
CSRF_TRUSTED_ORIGINS=

# ===== RATE LIMITING =====
RATELIMIT_ENABLE=True
MAX_LOGIN_ATTEMPTS=5
LOCKOUT_DURATION=900
REQUIRE_EMAIL_VERIFICATION_ATTEMPTS=10

# ===== OTP SETTINGS =====
OTP_EXPIRATION_MINUTES=10
OTP_RESEND_LIMIT=5
OTP_RESEND_COOLDOWN_MINUTES=2

# ===== BUSINESS INFORMATION =====
BUSINESS_NAME=TEEBUSINESS
BUSINESS_PHONE=+224 623 70 78 33
BUSINESS_EMAIL=supportteebusiness@gmail.com
