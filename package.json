{
  "name": "teebusiness-frontend",
  "version": "1.0.0",
  "private": true,
  "description": "Local Tailwind CSS v4 build workflow for the Django storefront.",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "dev": "tailwindcss -i ./frontend/tailwind.css -o ./static/css/tailwind.css",
    "watch": "tailwindcss -i ./frontend/tailwind.css -o ./static/css/tailwind.css --watch",
    "build": "tailwindcss -i ./frontend/tailwind.css -o ./static/css/tailwind.css --minify",
    "check:css": "node ./frontend/check-tailwind-classes.mjs"
  },
  "devDependencies": {
    "@tailwindcss/cli": "^4.3.1",
    "tailwindcss": "^4.3.1"
  }
}
