{
  "name": "teebusiness-frontend",
  "version": "1.0.0",
  "private": true,
  "description": "Minimal Tailwind CSS v4 build workflow for the Django storefront.",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "dev": "tailwindcss -i ./frontend/tailwind.css -o ./static/css/tailwind.generated.css",
    "watch": "tailwindcss -i ./frontend/tailwind.css -o ./static/css/tailwind.generated.css --watch",
    "build": "tailwindcss -i ./frontend/tailwind.css -o ./static/css/tailwind.generated.css --minify"
  },
  "devDependencies": {
    "@tailwindcss/cli": "^4.3.1",
    "tailwindcss": "^4.3.1"
  }
}
