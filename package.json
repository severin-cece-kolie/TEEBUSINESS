{
  "name": "teebusiness-frontend",
  "version": "1.0.0",
  "private": true,
  "description": "Tailwind CSS v4 coexistence and standalone build workflow for the Django storefront.",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "dev": "node ./frontend/tailwind-workflow.mjs",
    "watch": "node ./frontend/tailwind-workflow.mjs --watch",
    "build": "node ./frontend/tailwind-workflow.mjs --minify",
    "check:css": "node ./frontend/check-tailwind-classes.mjs"
  },
  "devDependencies": {
    "@tailwindcss/cli": "^4.3.1",
    "tailwindcss": "^4.3.1"
  }
}
